root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{c,cc,cpp,cxx,h,hpp}]
indent_style = tab
indent_size = 8

[Makefile]
indent_style = tab

[{CMakeLists.txt,*.cmake}]
indent_size = 2

[*.{gitattributes,gitconfig,gitignore}]
indent_size = 2

[*.toml]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
